#!/usr/bin/env bash
# LunchClaw — healthy food ordering agent via Telegram.
#
# Usage:
#   ./lunchclaw setup     Interactive setup wizard (first time)
#   ./lunchclaw start     Start the bot
#   ./lunchclaw stop      Stop the bot
#   ./lunchclaw status    Check bot health
#   ./lunchclaw logs      Stream bot logs
#   ./lunchclaw update    Rebuild and redeploy code
#   ./lunchclaw destroy   Remove the sandbox

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SANDBOX_NAME="lunchclaw"
SSH_HOST="openshell-${SANDBOX_NAME}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

step()  { echo -e "\n${BOLD}==> $1${NC}"; }
ok()    { echo -e "    ${GREEN}OK${NC}"; }
warn()  { echo -e "    ${YELLOW}$1${NC}"; }
fail()  { echo -e "    ${RED}$1${NC}"; exit 1; }

ensure_ssh_config() {
    if ! grep -q "openshell-${SANDBOX_NAME}" ~/.ssh/config 2>/dev/null; then
        openshell sandbox ssh-config "$SANDBOX_NAME" >> ~/.ssh/config
    fi
}

# ---------------------------------------------------------------------------
# setup — interactive first-time wizard
# ---------------------------------------------------------------------------
cmd_setup() {
    echo -e "${BOLD}"
    echo "  LunchClaw Setup"
    echo "  ==============="
    echo -e "${NC}"
    echo "  A healthy food ordering bot for Telegram."
    echo ""
    echo "  Powered by:"
    echo "    NVIDIA NemoClaw  https://github.com/NVIDIA/NemoClaw"
    echo "    NVIDIA OpenShell https://github.com/NVIDIA/OpenShell"
    echo ""
    echo "  LunchClaw runs inside a secure OpenShell sandbox with"
    echo "  network isolation, filesystem restrictions, and policy-enforced access."
    echo ""

    # --- Prerequisites ---
    step "Checking prerequisites"

    command -v openshell >/dev/null 2>&1 || fail "openshell not found. Install NemoClaw first: https://github.com/NVIDIA/NemoClaw"
    command -v docker >/dev/null 2>&1 || fail "Docker not found. Install Docker first."
    command -v node >/dev/null 2>&1 || fail "Node.js not found. Install Node.js 22+ first."
    command -v npm >/dev/null 2>&1 || fail "npm not found."

    # Check for hungry-cli
    if [ ! -d "$SCRIPT_DIR/../hungry-cli" ]; then
        step "Cloning hungry-cli"
        git clone https://github.com/ericksoa/hungry-cli.git "$SCRIPT_DIR/../hungry-cli"
    fi
    ok

    # --- Build locally ---
    step "Building hungry-cli"
    (cd "$SCRIPT_DIR/../hungry-cli" && npm install --silent && npm run build) 2>&1 | tail -1
    ok

    step "Building lunchclaw bot"
    (cd "$SCRIPT_DIR/sandbox-app" && npm install --silent && npm run build) 2>&1 | tail -1
    ok

    # --- Collect config ---
    step "Configuration"

    if [ -f "$SCRIPT_DIR/.env.local" ]; then
        echo "    Found existing .env.local"
        # shellcheck disable=SC1091
        source "$SCRIPT_DIR/.env.local"
    fi

    if [ -z "${TELEGRAM_BOT_TOKEN:-}" ]; then
        echo ""
        echo "    Step 1: Get a Telegram bot token"
        echo ""
        echo "    a) Install Telegram if you don't have it: https://telegram.org"
        echo "    b) Open Telegram and search for @BotFather (or go to https://t.me/BotFather)"
        echo "    c) Send /newbot to @BotFather"
        echo "    d) Choose a name for your bot (e.g., 'My LunchClaw')"
        echo "    e) Choose a username (must end in 'bot', e.g., 'mylunchclaw_bot')"
        echo "    f) @BotFather will reply with a token like: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz"
        echo ""
        read -rp "    Paste your bot token here: " TELEGRAM_BOT_TOKEN
    fi

    if [ -z "${TELEGRAM_ALLOWED_USER_ID:-}" ]; then
        echo ""
        echo "    Step 2: Get your Telegram user ID"
        echo ""
        echo "    a) In Telegram, search for @userinfobot (or go to https://t.me/userinfobot)"
        echo "    b) Send any message to @userinfobot"
        echo "    c) It will reply with your user ID (a number like 123456789)"
        echo ""
        read -rp "    Paste your user ID here: " TELEGRAM_ALLOWED_USER_ID
    fi

    if [ -z "${DELIVERY_ADDRESS:-}" ]; then
        echo ""
        echo "    Step 3: Delivery address"
        echo ""
        read -rp "    Enter your delivery address: " DELIVERY_ADDRESS
    fi

    # Save for future runs
    cat > "$SCRIPT_DIR/.env.local" << EOF
TELEGRAM_BOT_TOKEN="${TELEGRAM_BOT_TOKEN}"
TELEGRAM_ALLOWED_USER_ID="${TELEGRAM_ALLOWED_USER_ID}"
DELIVERY_ADDRESS="${DELIVERY_ADDRESS}"
EOF
    chmod 600 "$SCRIPT_DIR/.env.local"
    echo "    Config saved to .env.local"
    ok

    # --- Create sandbox via NemoClaw ---
    step "Creating NemoClaw sandbox"

    if nemoclaw list 2>/dev/null | awk '{print $1}' | grep -qx "$SANDBOX_NAME"; then
        echo "    Sandbox '$SANDBOX_NAME' already exists."
    else
        echo "    Running nemoclaw onboard with LunchClaw defaults..."
        # shellcheck disable=SC1091
        source "$SCRIPT_DIR/.env.local"
        export NEMOCLAW_NON_INTERACTIVE=1
        export NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1
        export NEMOCLAW_SANDBOX_NAME="$SANDBOX_NAME"
        export NEMOCLAW_PROVIDER="${NEMOCLAW_PROVIDER:-cloud}"
        export NEMOCLAW_POLICY_PRESETS="npm,telegram"
        export TELEGRAM_BOT_TOKEN
        nemoclaw onboard
    fi
    ensure_ssh_config
    ok

    # --- Apply LunchClaw network policy (merge into NemoClaw's base) ---
    step "Applying LunchClaw network policy"
    MERGED_POLICY=$(mktemp /tmp/lunchclaw-policy-XXXXXX.yaml)
    openshell policy get --full "$SANDBOX_NAME" 2>&1 | sed '1,/^---$/d' > "$MERGED_POLICY"
    # Append our delivery service + playwright network rules
    sed -n '/^  delivery_service:/,$ p' "$SCRIPT_DIR/policies/network.yaml" >> "$MERGED_POLICY"
    openshell policy set --policy "$MERGED_POLICY" --wait "$SANDBOX_NAME"
    rm -f "$MERGED_POLICY"
    ok

    # --- Upload code ---
    step "Deploying hungry-cli"
    openshell sandbox upload --no-git-ignore "$SANDBOX_NAME" "$SCRIPT_DIR/../hungry-cli" /sandbox/hungry-cli
    ok

    step "Deploying lunchclaw bot"
    openshell sandbox upload --no-git-ignore "$SANDBOX_NAME" "$SCRIPT_DIR/sandbox-app" /sandbox/lunchclaw
    ok

    step "Uploading workspace files"
    openshell sandbox upload "$SANDBOX_NAME" "$SCRIPT_DIR/workspace" /sandbox/.openclaw/workspace
    ok

    # --- Install deps in sandbox ---
    step "Installing dependencies in sandbox"
    ssh "$SSH_HOST" 'cd /sandbox/hungry-cli && npm install --omit=dev 2>&1 | tail -1'
    ssh "$SSH_HOST" 'cd /sandbox/lunchclaw && npm install --omit=dev 2>&1 | tail -1'
    ok

    # --- Install Playwright ---
    step "Installing browser engine"
    ssh "$SSH_HOST" 'cd /sandbox/hungry-cli && node node_modules/playwright/cli.js install chromium 2>&1 | grep -E "downloaded|Failed" || true'
    ok

    # --- Set environment ---
    step "Configuring environment"
    ssh "$SSH_HOST" "cat > /sandbox/.env << EOF
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
TELEGRAM_ALLOWED_USER_ID=${TELEGRAM_ALLOWED_USER_ID}
DELIVERY_ADDRESS=${DELIVERY_ADDRESS}
HUNGRY_CLI_PATH=/sandbox/hungry-cli/dist/cli.js
BUDGET_MAX=30
EOF"
    ok

    # --- Auth ---
    step "Delivery service authentication"
    echo ""
    echo "    You need to log into your delivery service once."
    echo "    This opens a browser on YOUR machine (not inside the sandbox),"
    echo "    then uploads the session to the sandbox."
    echo ""

    # Check if already authed locally
    local auth_dir="$HOME/.config/hungry/ubereats"
    if [ -d "$auth_dir/chrome-profile" ] && [ -f "$auth_dir/auth.json" ]; then
        echo "    Found existing local session."
        read -rp "    Use it? (Y/n): " use_existing
        if [ "${use_existing:-y}" != "n" ] && [ "${use_existing:-y}" != "N" ]; then
            echo "    Uploading session to sandbox..."
            openshell sandbox upload "$SANDBOX_NAME" "$auth_dir" /sandbox/.config/hungry/ubereats
            ok
        else
            cmd_auth_local
        fi
    else
        cmd_auth_local
    fi

    # --- Start ---
    cmd_start

    echo ""
    echo -e "${BOLD}  ===============${NC}"
    echo -e "${BOLD}  LunchClaw is ready!${NC}"
    echo ""
    echo "  Message your bot on Telegram."
    echo "  Try: \"hungry, something with chicken\""
    echo ""
    echo "  Commands:"
    echo "    ./lunchclaw status    Check health"
    echo "    ./lunchclaw logs      Stream logs"
    echo "    ./lunchclaw stop      Stop the bot"
    echo "    ./lunchclaw start     Start the bot"
    echo "    ./lunchclaw update    Rebuild and redeploy"
}

# ---------------------------------------------------------------------------
# start / stop / status / logs
# ---------------------------------------------------------------------------
cmd_start() {
    step "Starting LunchClaw"
    ensure_ssh_config
    ssh "$SSH_HOST" 'pkill -f "node.*bot.js" 2>/dev/null || true'
    sleep 1
    ssh "$SSH_HOST" 'cd /sandbox/lunchclaw && nohup node dist/bot.js >> /sandbox/lunchclaw.log 2>&1 &'
    sleep 2
    if ssh "$SSH_HOST" 'pgrep -f "node.*bot.js" > /dev/null 2>&1'; then
        ok
        echo "    Bot is running."
    else
        fail "Bot failed to start. Run './lunchclaw logs' to debug."
    fi
}

cmd_stop() {
    step "Stopping LunchClaw"
    ensure_ssh_config
    ssh "$SSH_HOST" 'pkill -f "node.*bot.js" 2>/dev/null || true'
    ok
}

cmd_status() {
    ensure_ssh_config
    echo -e "${BOLD}LunchClaw Status${NC}"
    echo ""
    if ssh "$SSH_HOST" 'pgrep -f "node.*bot.js" > /dev/null 2>&1'; then
        echo -e "  Bot:     ${GREEN}running${NC}"
    else
        echo -e "  Bot:     ${RED}stopped${NC}"
    fi
    echo "  Sandbox: $SANDBOX_NAME"
    echo ""
    echo "  Last log lines:"
    ssh "$SSH_HOST" 'tail -5 /sandbox/lunchclaw.log 2>/dev/null' || echo "  (no logs yet)"
}

cmd_logs() {
    ensure_ssh_config
    ssh "$SSH_HOST" 'tail -f /sandbox/lunchclaw.log'
}

cmd_update() {
    step "Rebuilding"
    (cd "$SCRIPT_DIR/../hungry-cli" && npm run build) 2>&1 | tail -1
    (cd "$SCRIPT_DIR/sandbox-app" && npm run build) 2>&1 | tail -1
    ok

    step "Uploading"
    ensure_ssh_config
    openshell sandbox upload --no-git-ignore "$SANDBOX_NAME" "$SCRIPT_DIR/../hungry-cli" /sandbox/hungry-cli
    openshell sandbox upload --no-git-ignore "$SANDBOX_NAME" "$SCRIPT_DIR/sandbox-app" /sandbox/lunchclaw
    openshell sandbox upload "$SANDBOX_NAME" "$SCRIPT_DIR/workspace" /sandbox/.openclaw/workspace
    ok

    cmd_start
}

cmd_auth_local() {
    # Run auth locally where Chrome can open a visible window,
    # then upload the session to the sandbox.
    local hungry_cli="$SCRIPT_DIR/../hungry-cli"

    echo ""
    echo "    Opening Chrome on your machine to log in..."
    echo "    Log in, then press Enter in the terminal when done."
    echo ""

    (cd "$hungry_cli" && node dist/cli.js auth)

    local auth_dir="$HOME/.config/hungry/ubereats"
    if [ -d "$auth_dir/chrome-profile" ]; then
        echo "    Uploading session to sandbox..."
        ensure_ssh_config
        openshell sandbox upload "$SANDBOX_NAME" "$auth_dir" /sandbox/.config/hungry/ubereats
        ok
    else
        warn "Auth may not have completed. Run './lunchclaw auth' to retry."
    fi
}

cmd_auth() {
    cmd_auth_local
}

cmd_destroy() {
    echo -e "${RED}This will permanently delete the lunchclaw sandbox and all data.${NC}"
    read -rp "Are you sure? (yes/no): " confirm
    if [ "$confirm" = "yes" ]; then
        openshell sandbox delete "$SANDBOX_NAME"
        echo "Sandbox deleted."
    else
        echo "Cancelled."
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
case "${1:-help}" in
    setup)   cmd_setup ;;
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    update)  cmd_update ;;
    auth)    cmd_auth ;;
    destroy) cmd_destroy ;;
    help|--help|-h)
        echo "Usage: ./lunchclaw <command>"
        echo ""
        echo "Commands:"
        echo "  setup     Interactive first-time setup"
        echo "  start     Start the bot"
        echo "  stop      Stop the bot"
        echo "  status    Check bot health"
        echo "  logs      Stream bot logs"
        echo "  update    Rebuild and redeploy code"
        echo "  auth      Re-authenticate with delivery service"
        echo "  destroy   Remove the sandbox (permanent)"
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run './lunchclaw help' for usage."
        exit 1
        ;;
esac
